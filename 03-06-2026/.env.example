# Copie este arquivo para ".env" e cole os valores do SEU projeto no Firebase Console.
# (Configurações do projeto > Seus apps > App da Web > SDK setup and configuration)
#
# Obs.: estas chaves "Web" do Firebase NÃO são secretas — são identificadores
# públicos do projeto. A segurança vem das regras e dos "domínios autorizados".
# Mesmo assim, é boa prática mantê-las fora do código-fonte.

VITE_FIREBASE_API_KEY=cole_sua_api_key_aqui
VITE_FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=seu-projeto
VITE_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000
